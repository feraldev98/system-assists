{
  "name": "system-assists",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"cyan,magenta\" \"pnpm --filter backend run dev\" \"pnpm --filter frontend run dev\"",    
    "dev:backend": "pnpm --filter backend run dev",
    "dev:frontend": "pnpm --filter frontend run dev",
    "setup:backend": "pnpm --filter backend run setup",
    "setup:frontend": "",
    "build:backend": "pnpm --filter backend run build",
    "build:frontend": "pnpm --filter frontend run build",
    "setup": "pnpm run setup:backend",
    "build": "pnpm run build:backend && pnpm run build:frontend"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wynsley/system-assists.git"
  },
