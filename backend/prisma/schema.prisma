// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  AUXILIAR
  PARENT
}

model User {
  idUser       Int          @id @default(autoincrement())
  firstname    String       @db.VarChar(50)
  lastname     String       @db.VarChar(50)
  email        String       @unique @db.VarChar(100)
  passwordHash String
  role         Role
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  parents      Parent[]
  attendances  Attendance[]
  incidents    Incident[]
}

model Grade {
  idGrade  Int       @id @default(autoincrement())
  level    Int       @unique
  sections Section[]
}

model Section {
  idSection Int       @id @default(autoincrement())
  name      String    @db.VarChar(10)
  grade     Grade     @relation(fields: [idGrade], references: [idGrade])
  idGrade   Int
  students  Student[]
}

model Student {
  idStudent            Int                   @id @default(autoincrement())
  firstname            String                @db.VarChar(50)
  lastname             String                @db.VarChar(50)
  code                 String                @unique @default(uuid()) @db.Uuid
  active               Boolean               @default(true)
  section              Section               @relation(fields: [idSection], references: [idSection])
  idSection            Int
  parentStudentDetails ParentStudentDetail[]
  attendances          Attendance[]
  incidents            Incident[]

  @@index([idSection])
}

model Parent {
  idParent             Int                   @id @default(autoincrement())
  phone                String                @unique @db.VarChar(15)
  user                 User                  @relation(fields: [idUser], references: [idUser])
  idUser               Int
  parentStudentDetails ParentStudentDetail[]
}

model ParentStudentDetail {
  student   Student @relation(fields: [idStudent], references: [idStudent])
  idStudent Int
  parent    Parent  @relation(fields: [idParent], references: [idParent])
  idParent  Int

  @@id([idParent, idStudent])
}

enum Status {
  PRESENT
  LATE
  ABSENT
}

enum Method {
  QR
  NAME
}

model Attendance {
  idAttendance Int      @id @default(autoincrement())
  status       Status
  method       Method
  createdBy    User     @relation(fields: [idCreatedBy], references: [idUser])
  idCreatedBy  Int
  createdAt    DateTime @default(now())
  date         DateTime @db.Date
  student      Student  @relation(fields: [idStudent], references: [idStudent])
  idStudent    Int

  @@unique([idStudent, date])
  @@index([date])
}

enum Severity {
  LOW
  MEDIUM
  HIGH
}

enum IncidentType {
  DISCIPLINE
  LATE
  UNIFORM
  OTHER
}

model Incident {
  idIncident  Int          @id @default(autoincrement())
  type        IncidentType
  points      Int
  description String       @db.Text
  severity    Severity
  createdBy   User         @relation(fields: [idCreatedBy], references: [idUser])
  idCreatedBy Int
  createdAt   DateTime     @default(now())
  student     Student      @relation(fields: [idStudent], references: [idStudent])
  idStudent   Int

  @@index([createdAt])
  @@index([idStudent, createdAt])
}
