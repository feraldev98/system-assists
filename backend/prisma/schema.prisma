// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  AUXILIAR
  PARENT
}

model User {
  idUser         Int             @id @default(autoincrement())
  firstname      String          @db.VarChar(50)
  lastname       String          @db.VarChar(50)
  email          String          @unique @db.VarChar(100)
  passwordHash   String          @db.VarChar(255)
  role           Role
  phone          String?         @db.VarChar(20)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  studentParents StudentParent[]
  attendances    Attendance[]
  incidents      Incident[]
}

model Grade {
  idGrade  Int       @id @default(autoincrement())
  level    Int       @unique
  sections Section[]
}

model Section {
  idSection  Int         @id @default(autoincrement())
  name       String      @db.VarChar(10)
  grade      Grade       @relation(fields: [idGrade], references: [idGrade])
  idGrade    Int
  classrooms Classroom[]

  @@unique([name, idGrade])
}

enum StatusStudent {
  ACTIVO
  INACTIVO
  SUSPENDIDO
  EXPULSADO
  TRANSFERIDO
  GRADUADO
  RETIRADO
}

enum Gender {
  M
  F
  O
}

model Student {
  idStudent         Int                @id @default(autoincrement())
  firstname         String             @db.VarChar(50)
  lastname          String             @db.VarChar(50)
  dni               String             @unique @db.VarChar(20)
  phone             String?            @unique @db.VarChar(20)
  email             String?            @unique @db.VarChar(100)
  gender            Gender
  status            StatusStudent      @default(ACTIVO)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  studentParents    StudentParent[]
  classroomStudents ClassroomStudent[]
  attendances       Attendance[]
  incidents         Incident[]
}

enum Relationship {
  PADRE
  MADRE
  ABUELO
  ABUELA
  TÍO
  TÍA
  APODERADO
  OTRO
}

model StudentParent {
  idStudentParent Int          @id @default(autoincrement())
  idStudent       Int
  idParent        Int
  relationship    Relationship @default(APODERADO)

  student Student @relation(fields: [idStudent], references: [idStudent])
  parent  User    @relation(fields: [idParent], references: [idUser])

  @@unique([idStudent, idParent])
  @@index([idStudent])
  @@index([idParent])
}

enum StatusClassroom {
  ACTIVO
  INACTIVO
}

model Classroom {
  idClassroom Int             @id @default(autoincrement())
  year        Int
  idSection   Int
  status      StatusClassroom

  section           Section            @relation(fields: [idSection], references: [idSection])
  classroomStudents ClassroomStudent[]

  @@unique([year, idSection])
  @@index([idSection])
  @@index([year])
}

model ClassroomStudent {
  idClassroomStudent Int @id @default(autoincrement())
  idClassroom        Int
  idStudent          Int

  classroom Classroom @relation(fields: [idClassroom], references: [idClassroom])
  student   Student   @relation(fields: [idStudent], references: [idStudent])

  @@unique([idClassroom, idStudent])
}

enum StatusAssistance {
  PRESENTE
  TARDANZA
  JUSTIFICADA
}

model Attendance {
  idAttendance Int              @id @default(autoincrement())
  date         DateTime         @db.Date
  status       StatusAssistance @default(PRESENTE)
  note         String?          @db.VarChar(100)
  idStudent    Int
  idAuxiliar   Int
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  student  Student @relation(fields: [idStudent], references: [idStudent])
  auxiliar User    @relation(fields: [idAuxiliar], references: [idUser])

  @@unique([idStudent, date])
  @@index([idStudent])
  @@index([idAuxiliar])
  @@index([date])
  @@index([idStudent, date])
}

enum IncidentType {
  LEVE
  GRAVE
  MUY_GRAVE
}

model IncidentCatalog {
  idIncidentCatalog Int @id @default(autoincrement())

  name          String @unique
  description   String?
  type          IncidentType
  pointsDeducted Int

  incidents Incident[]
}

model Incident {
  idIncident        Int      @id @default(autoincrement())

  date              DateTime @db.Date
  note              String?  @db.VarChar(255)

  idStudent         Int
  idAuxiliar        Int
  idIncidentCatalog Int

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  student           Student @relation(fields: [idStudent], references: [idStudent])
  auxiliar          User @relation(fields: [idAuxiliar], references: [idUser])
  incidentCatalog   IncidentCatalog @relation(fields: [idIncidentCatalog], references: [idIncidentCatalog])

  @@unique([idStudent, date, idIncidentCatalog])

  @@index([idAuxiliar])
  @@index([idIncidentCatalog])
  @@index([date])
  @@index([idStudent, date])
  @@index([idAuxiliar, date])
}
